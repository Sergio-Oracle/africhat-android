<?xml version="1.0" encoding="utf-8"?>
<!--
  AfriChat onboarding background.
  African kente-inspired geometric pattern on deep green.
  Light theme version.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="1080dp"
    android:height="1920dp"
    android:viewportWidth="1080"
    android:viewportHeight="1920">

    <!-- Base deep green background -->
    <path
        android:fillColor="#006B3C"
        android:pathData="M0,0 L1080,0 L1080,1920 L0,1920 Z" />

    <!-- Radial glow top-center (lighter green) -->
    <path
        android:fillColor="#1A8C52"
        android:pathData="M540,0 C750,0 900,200 900,380 C900,560 750,700 540,700 C330,700 180,560 180,380 C180,200 330,0 540,0 Z"
        android:fillAlpha="0.35" />

    <!-- === Kente / Adinkra geometric pattern === -->

    <!-- Top band: horizontal gold stripe -->
    <path
        android:fillColor="#FCD116"
        android:pathData="M0,140 L1080,140 L1080,170 L0,170 Z"
        android:fillAlpha="0.25" />

    <!-- Top band: thin red stripe -->
    <path
        android:fillColor="#CE1126"
        android:pathData="M0,172 L1080,172 L1080,182 L0,182 Z"
        android:fillAlpha="0.2" />

    <!-- Diamond grid pattern (top-right area) -->
    <!-- Row 1 -->
    <path
        android:fillColor="#FCD116"
        android:pathData="M820,220 L860,260 L820,300 L780,260 Z"
        android:fillAlpha="0.18" />
    <path
        android:fillColor="#FCD116"
        android:pathData="M900,220 L940,260 L900,300 L860,260 Z"
        android:fillAlpha="0.18" />
    <path
        android:fillColor="#FCD116"
        android:pathData="M980,220 L1020,260 L980,300 L940,260 Z"
        android:fillAlpha="0.18" />

    <!-- Row 2 -->
    <path
        android:fillColor="#FCD116"
        android:pathData="M860,300 L900,340 L860,380 L820,340 Z"
        android:fillAlpha="0.12" />
    <path
        android:fillColor="#FCD116"
        android:pathData="M940,300 L980,340 L940,380 L900,340 Z"
        android:fillAlpha="0.12" />

    <!-- Left column small squares -->
    <path
        android:fillColor="#FCD116"
        android:pathData="M30,300 L70,300 L70,340 L30,340 Z"
        android:fillAlpha="0.12" />
    <path
        android:fillColor="#FCD116"
        android:pathData="M30,360 L70,360 L70,400 L30,400 Z"
        android:fillAlpha="0.08" />

    <!-- Mid vertical accent bar left -->
    <path
        android:fillColor="#FCD116"
        android:pathData="M0,600 L15,600 L15,900 L0,900 Z"
        android:fillAlpha="0.2" />
    <path
        android:fillColor="#CE1126"
        android:pathData="M17,600 L28,600 L28,900 L17,900 Z"
        android:fillAlpha="0.15" />

    <!-- Mid vertical accent bar right -->
    <path
        android:fillColor="#FCD116"
        android:pathData="M1065,600 L1080,600 L1080,900 L1065,900 Z"
        android:fillAlpha="0.2" />
    <path
        android:fillColor="#CE1126"
        android:pathData="M1052,600 L1063,600 L1063,900 L1052,900 Z"
        android:fillAlpha="0.15" />

    <!-- Horizontal mid stripe faint -->
    <path
        android:fillColor="#FCD116"
        android:pathData="M0,950 L1080,950 L1080,960 L0,960 Z"
        android:fillAlpha="0.1" />

    <!-- Bottom area: adinkra-style cross motifs -->
    <!-- Cross 1 -->
    <path
        android:fillColor="#FCD116"
        android:pathData="M80,1350 L110,1350 L110,1450 L80,1450 Z"
        android:fillAlpha="0.1" />
    <path
        android:fillColor="#FCD116"
        android:pathData="M40,1380 L150,1380 L150,1420 L40,1420 Z"
        android:fillAlpha="0.1" />

    <!-- Cross 2 -->
    <path
        android:fillColor="#FCD116"
        android:pathData="M950,1350 L980,1350 L980,1450 L950,1450 Z"
        android:fillAlpha="0.1" />
    <path
        android:fillColor="#FCD116"
        android:pathData="M910,1380 L1020,1380 L1020,1420 L910,1420 Z"
        android:fillAlpha="0.1" />

    <!-- Bottom band: gold stripe -->
    <path
        android:fillColor="#FCD116"
        android:pathData="M0,1750 L1080,1750 L1080,1780 L0,1780 Z"
        android:fillAlpha="0.25" />
    <path
        android:fillColor="#CE1126"
        android:pathData="M0,1782 L1080,1782 L1080,1792 L0,1792 Z"
        android:fillAlpha="0.2" />

    <!-- Subtle diagonal lines (top-left to bottom-right) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M-100,500 L100,500 L600,1920 L400,1920 Z"
        android:fillAlpha="0.02" />
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M300,0 L500,0 L1080,1300 L880,1300 Z"
        android:fillAlpha="0.02" />
</vector>
